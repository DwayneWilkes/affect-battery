# direnv configuration: auto-activate this project's .venv on cd-in,
# auto-deactivate on cd-out. Avoids the `VIRTUAL_ENV mismatch` warning
# from uv when the parent shell has another project's venv activated.
#
# Setup (one-time, per-machine):
#   sudo apt install direnv          # or: brew install direnv
#   echo 'eval "$(direnv hook bash)"' >> ~/.bashrc   # or zsh equiv
#   exec bash                         # reload the shell
#   direnv allow                      # in each project once

# Activate the project's .venv (created by `uv sync`) if present.
# Falls through silently when the project hasn't been synced yet
# so this script is safe for fresh clones.
if [[ -f .venv/bin/activate ]]; then
  source .venv/bin/activate
fi

# Make ANTHROPIC_API_KEY / OPENAI_API_KEY available from a
# gitignored .envrc.local if the user has one. Keeps secrets out of
# the committed .envrc while letting cd-into-project pre-load them.
if [[ -f .envrc.local ]]; then
  source_env .envrc.local
fi
